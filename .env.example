# Bilibili 评论自动回复机器人环境变量配置
# 复制此文件为 .env 并填入真实值

# DeepSeek API Key（主 AI Provider）
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Tavily API Key（联网搜索，未配置则只用 DuckDuckGo）
TAVILY_API_KEY=your_tavily_api_key_here

# Bilibili Refresh Token（用于 Cookie 自动刷新）
# 从浏览器 localStorage 中的 ac_time_value 获取
BILIBILI_REFRESH_TOKEN=your_refresh_token_here
